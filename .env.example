# ============================================================
#  Kinetic Clinical OS — 환경 변수 템플릿
#  이 파일을 복사해서 .env.local 을 만들고 실제 값을 입력하세요.
#  .env.local 은 .gitignore 에 포함되어 절대 커밋되지 않습니다.
# ============================================================

# ── 앱 모드 ────────────────────────────────────────────────────
VITE_APP_ENV=development        # development | production

# ── DB 모드 ────────────────────────────────────────────────────
# false = 브라우저 localStorage (기본값, 개발용)
# true  = Supabase 클라우드 DB (실서비스용, 아래 키 필요)
VITE_USE_CLOUD_DB=false

# ── Supabase (VITE_USE_CLOUD_DB=true 일 때만 필요) ─────────────
# Supabase 대시보드 > Settings > API 에서 확인
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 앱 정보 (선택) ─────────────────────────────────────────────
VITE_APP_NAME=Kinetic Clinical OS
VITE_APP_VERSION=1.0.0
